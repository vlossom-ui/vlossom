{
    "name": "vlossom",
    "description": "Vlossom UI components for Vue",
    "version": "2.0.0-alpha.1",
    "author": "vlossom",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vlossom-ui/vlossom.git"
    },
    "bugs": {
        "url": "https://github.com/vlossom-ui/vlossom/issues"
    },
    "license": "MIT",
    "keywords": [
        "vlossom",
        "vue",
        "components",
        "ui framework",
        "component library"
    ],
    "type": "module",
    "sideEffects": [
        "*.css",
        "*.vue"
    ],
    "scripts": {
        "dev": "vite --config vite.config.playground.ts",
        "type-check": "vue-tsc --build",
        "build": "run-p type-check \"build-only {@}\" --",
        "build-only": "vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . && stylelint \"src/**/*.{css,scss}\"",
        "format": "prettier --write src/**/*.{js,ts,vue,json}",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "build-storybook:chromatic": "storybook build -c .storybook-chromatic",
        "chromatic": "chromatic --build-script-name build-storybook:chromatic --exit-zero-on-changes"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/vlossom.umd.js",
    "module": "./dist/vlossom.es.js",
    "unpkg": "./dist/vlossom.umd.js",
    "jsdelivr": "./dist/vlossom.umd.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/vlossom.es.js",
            "require": "./dist/vlossom.umd.js"
        },
        "./styles": "./dist/vlossom.css"
    },
    "dependencies": {
        "@vueuse/core": "^13.6.0",
        "change-case": "^5.4.4",
        "nanoid": "^5.1.5",
        "radash": "^12.1.1",
        "vue": "^3.5.26",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "5.0.0",
        "@storybook/addon-a11y": "10.1.11",
        "@storybook/addon-docs": "10.1.11",
        "@storybook/addon-vitest": "10.1.11",
        "@storybook/builder-vite": "^10.1.11",
        "@storybook/vue3-vite": "10.1.11",
        "@tailwindcss/vite": "^4.1.11",
        "@tsconfig/node24": "^24.0.3",
        "@types/jsdom": "^27.0.0",
        "@types/node": "^25.0.3",
        "@types/sortablejs": "^1.15.9",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/browser": "4.0.16",
        "@vitest/browser-playwright": "^4.0.16",
        "@vitest/coverage-v8": "4.0.16",
        "@vitest/eslint-plugin": "^1.6.5",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.7.0",
        "chromatic": "^13.1.3",
        "eslint": "^9.32.0",
        "eslint-plugin-storybook": "10.1.11",
        "eslint-plugin-vue": "~10.2.0",
        "glob": "^13.0.0",
        "jiti": "^2.5.1",
        "jsdom": "^26.1.0",
        "npm-run-all2": "^8.0.4",
        "playwright": "^1.54.2",
        "prettier": "3.5.3",
        "prettier-plugin-classnames": "^0.8.2",
        "prettier-plugin-css-order": "^2.1.2",
        "prettier-plugin-merge": "^0.8.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "rollup-plugin-visualizer": "^6.0.3",
        "sass": "^1.90.0",
        "storybook": "10.1.11",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-value-no-unknown-custom-properties": "^6.1.0",
        "tailwindcss": "^4.1.11",
        "typescript": "~5.8.3",
        "vite": "^7.0.6",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-vue-devtools": "^7.7.7",
        "vitest": "^3.2.4",
        "vue-tsc": "^2.2.12"
    }
}
