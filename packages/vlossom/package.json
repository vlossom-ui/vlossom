{
    "name": "vlossom",
    "description": "Vlossom UI components for Vue",
    "version": "2.0.0-beta.2",
    "author": "vlossom",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vlossom-ui/vlossom.git"
    },
    "bugs": {
        "url": "https://github.com/vlossom-ui/vlossom/issues"
    },
    "license": "MIT",
    "keywords": [
        "vlossom",
        "vue",
        "components",
        "ui framework",
        "component library"
    ],
    "type": "module",
    "scripts": {
        "dev": "vite --config vite.config.playground.ts",
        "type-check": "vue-tsc --build",
        "build": "run-p type-check \"build-only {@}\" --",
        "build-only": "vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . && stylelint \"src/**/*.{css,scss}\"",
        "format": "prettier --write src/**/*.{js,ts,vue,json}",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "build-storybook:chromatic": "storybook build -c .storybook-chromatic",
        "chromatic": "chromatic --build-script-name build-storybook:chromatic --exit-zero-on-changes"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "main": "./dist/vlossom.umd.js",
    "module": "./dist/vlossom.es.js",
    "unpkg": "./dist/vlossom.umd.js",
    "jsdelivr": "./dist/vlossom.umd.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/vlossom.es.js",
            "require": "./dist/vlossom.umd.js"
        },
        "./styles": {
            "types": "./dist/vlossom-styles.d.ts",
            "default": "./dist/vlossom.css"
        }
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "change-case": "^5.4.4",
        "nanoid": "^5.1.9",
        "radash": "^12.1.1",
        "vue": "^3.5.33",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "5.1.2",
        "@storybook/addon-a11y": "10.3.5",
        "@storybook/addon-docs": "10.3.5",
        "@storybook/builder-vite": "^10.3.5",
        "@storybook/vue3-vite": "10.3.5",
        "@tailwindcss/vite": "^4.2.4",
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^28.0.1",
        "@types/node": "24",
        "@types/sortablejs": "^1.15.9",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/eslint-plugin": "^1.6.16",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.8",
        "@vue/tsconfig": "^0.9.1",
        "chromatic": "^16.6.0",
        "eslint": "^10.2.1",
        "eslint-plugin-storybook": "10.3.5",
        "eslint-plugin-vue": "~10.9.0",
        "glob": "^13.0.6",
        "jiti": "^2.6.1",
        "jsdom": "^29.1.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "3.8.3",
        "prettier-plugin-classnames": "^0.10.1",
        "prettier-plugin-css-order": "^2.2.0",
        "prettier-plugin-merge": "^0.10.1",
        "prettier-plugin-tailwindcss": "^0.7.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.99.0",
        "storybook": "10.3.5",
        "stylelint": "^17.9.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-value-no-unknown-custom-properties": "^6.1.1",
        "tailwindcss": "^4.2.4",
        "typescript": "~5.9.3",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-vue-devtools": "^8.1.1",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.7"
    }
}
