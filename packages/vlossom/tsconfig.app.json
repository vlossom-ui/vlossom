{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["src/**/*", "src/**/*.vue", "shims.d.ts"],
    "exclude": [
        "src/**/__tests__/*",
        "src/**/__stories__/*",
        "src/**/README.md",
        ".storybook/**/*",
        ".storybook-chromatic/**/*"
    ],
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
