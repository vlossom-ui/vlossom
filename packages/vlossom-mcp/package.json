{
  "name": "vlossom-mcp",
  "version": "0.12.3",
  "description": "MCP server for Vlossom UI component library",
  "type": "module",
  "bin": {
    "vlossom-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "generate": "node scripts/generate-components.mjs && node scripts/build-meta.mjs && node scripts/build-sources.mjs && node scripts/build-tokens.mjs && node scripts/build-changelog.mjs",
    "prepublishOnly": "npm run generate && npm run build",
    "release:patch": "npm version patch --no-git-tag-version && pnpm publish",
    "release:minor": "npm version minor --no-git-tag-version && pnpm publish",
    "release:major": "npm version major --no-git-tag-version && pnpm publish"
  },
  "files": [
    "dist",
    "skill"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vlossom-ui/vlossom.git",
    "directory": "packages/vlossom-mcp"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "vlossom",
    "vue",
    "ui-components",
    "claude"
  ]
}
